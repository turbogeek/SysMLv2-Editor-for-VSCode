{
	"name": "sysmlv2-lsp",
	"displayName": "SysMLv2 Editor",
	"description": "Language server and advanced editor for SysMLv2 and KerML",
	"author": "turbogeek",
	"license": "MIT",
	"version": "1.0.7",
	"publisher": "turbogeek",
	"icon": "images/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/turbogeek/SysMLv2-Editor-for-VSCode.git"
	},
	"categories": [
		"Programming Languages"
	],
	"keywords": [
		"sysmlv2",
		"kerml",
		"mbse"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"activationEvents": [
		"onLanguage:sysml",
		"onLanguage:kerml"
	],
	"main": "./client/out/extension",
	"contributes": {
		"languages": [
			{
				"id": "sysml",
				"aliases": [
					"SysMLv2",
					"sysml"
				],
				"extensions": [
					".sysml"
				]
			},
			{
				"id": "kerml",
				"aliases": [
					"KerML",
					"kerml"
				],
				"extensions": [
					".kerml"
				]
			}
		],
		"grammars": [
			{
				"language": "sysml",
				"scopeName": "source.sysml",
				"path": "./syntaxes/sysml.tmLanguage.json"
			},
			{
				"language": "kerml",
				"scopeName": "source.sysml",
				"path": "./syntaxes/sysml.tmLanguage.json"
			}
		],
		"configuration": {
			"type": "object",
			"title": "SysMLv2 configuration",
			"properties": {
				"sysmlv2.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Controls the maximum number of problems produced by the server."
				},
				"sysmlv2.warnOnSingleLineComments": {
					"scope": "resource",
					"type": "boolean",
					"default": true,
					"description": "Warn when single line comments (//) are used, as they are not added to the language model."
				},
				"sysmlv2.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the language server."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint",
		"postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"eslint": "^9.13.0",
		"mocha": "^10.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}